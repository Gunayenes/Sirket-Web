generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id          String              @id @default(cuid())
  slug        String              @unique
  icon        String
  order       Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  translations ServiceTranslation[]

  @@map("services")
}

model ServiceTranslation {
  id          String  @id @default(cuid())
  serviceId   String
  locale      String
  title       String
  description String  @db.Text
  features    Json    @default("[]")
  ctaText     String?
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@map("service_translations")
}

// ─── Projects ────────────────────────────────────────────────────────────────

model ProjectCategory {
  id           String                      @id @default(cuid())
  slug         String                      @unique
  createdAt    DateTime                    @default(now())
  projects     Project[]
  translations ProjectCategoryTranslation[]

  @@map("project_categories")
}

model ProjectCategoryTranslation {
  id         String          @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("project_category_translations")
}

model Project {
  id           String              @id @default(cuid())
  slug         String              @unique
  image        String
  externalUrl  String?
  technologies String[]
  isFeatured   Boolean             @default(false)
  order        Int                 @default(0)
  isActive     Boolean             @default(true)
  categoryId   String?
  category     ProjectCategory?    @relation(fields: [categoryId], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  translations ProjectTranslation[]

  @@map("projects")
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  locale      String
  title       String
  description String  @db.Text
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@map("project_translations")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogCategory {
  id           String                    @id @default(cuid())
  slug         String                    @unique
  createdAt    DateTime                  @default(now())
  posts        BlogPost[]
  translations BlogCategoryTranslation[]

  @@map("blog_categories")
}

model BlogCategoryTranslation {
  id         String       @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("blog_category_translations")
}

model BlogPost {
  id           String                @id @default(cuid())
  slug         String                @unique
  coverImage   String?
  tags         String[]
  isFeatured   Boolean               @default(false)
  isPublished  Boolean               @default(false)
  publishedAt  DateTime?
  authorId     String?
  categoryId   String?
  category     BlogCategory?         @relation(fields: [categoryId], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  translations BlogPostTranslation[]

  @@map("blog_posts")
}

model BlogPostTranslation {
  id          String   @id @default(cuid())
  postId      String
  locale      String
  title       String
  excerpt     String   @db.Text
  content     String   @db.Text
  metaTitle   String?
  metaDesc    String?
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@map("blog_post_translations")
}

// ─── Team ─────────────────────────────────────────────────────────────────────

model TeamMember {
  id           String                  @id @default(cuid())
  photo        String?
  email        String?
  linkedin     String?
  twitter      String?
  order        Int                     @default(0)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations TeamMemberTranslation[]

  @@map("team_members")
}

model TeamMemberTranslation {
  id         String     @id @default(cuid())
  memberId   String
  locale     String
  name       String
  role       String
  bio        String?    @db.Text
  member     TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, locale])
  @@map("team_member_translations")
}

// ─── Contact & Quotes ────────────────────────────────────────────────────────

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_messages")
}

model QuoteRequest {
  id          String       @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  budget      String?
  deadline    String?
  description String       @db.Text
  services    String[]
  status      QuoteStatus  @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("quote_requests")
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum QuoteStatus {
  PENDING
  IN_REVIEW
  QUOTED
  ACCEPTED
  REJECTED
}

// ─── Media ────────────────────────────────────────────────────────────────────

model MediaFile {
  id        String    @id @default(cuid())
  filename  String
  url       String
  alt       String?
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  folder    String?
  createdAt DateTime  @default(now())

  @@map("media_files")
}

// ─── SEO ─────────────────────────────────────────────────────────────────────

model SeoEntry {
  id            String   @id @default(cuid())
  page          String
  locale        String
  title         String
  description   String
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  keywords      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([page, locale])
  @@map("seo_entries")
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── Page Content ────────────────────────────────────────────────────────────

model PageContent {
  id           String                  @id @default(cuid())
  page         String                  // e.g., "about", "contact", "home"
  section      String                  // e.g., "story", "mission", "vision", "values"
  contentType  ContentType             @default(RICH_TEXT)
  order        Int                     @default(0)
  isActive     Boolean                 @default(true)
  metadata     Json?                   // Extra structured data (icon, image, stat values, etc.)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations PageContentTranslation[]

  @@unique([page, section])
  @@map("page_contents")
}

model PageContentTranslation {
  id        String      @id @default(cuid())
  contentId String
  locale    String
  title     String?
  subtitle  String?
  body      String?     @db.Text
  content   PageContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, locale])
  @@map("page_content_translations")
}

enum ContentType {
  RICH_TEXT
  STATS
  VALUES_LIST
  FAQ
  FEATURE_LIST
}

// ─── Navigation ───────────────────────────────────────────────────────────────

model MenuItem {
  id           String              @id @default(cuid())
  location     MenuLocation
  parentId     String?
  url          String
  order        Int                 @default(0)
  isActive     Boolean             @default(true)
  openInNew    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  parent       MenuItem?           @relation("MenuItemToMenuItem", fields: [parentId], references: [id])
  children     MenuItem[]          @relation("MenuItemToMenuItem")
  translations MenuItemTranslation[]

  @@map("menu_items")
}

model MenuItemTranslation {
  id       String   @id @default(cuid())
  itemId   String
  locale   String
  label    String
  item     MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
  @@map("menu_item_translations")
}

enum MenuLocation {
  HEADER
  FOOTER_COL1
  FOOTER_COL2
  FOOTER_COL3
}
